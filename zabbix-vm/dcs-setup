#!/usr/bin/env bash
# dcs-setup: TUI to join a Zabbix VM to its district's tailnet scope.
#
# Flow:
#   1. Prompt for district slug, hostname (optional), authkey
#   2. Run `tailscale up --authkey ... --ssh --accept-routes --accept-dns=false`
#   3. Validate that the authkey placed this node under tag:zabbix-<district>
#   4. Persist enrollment metadata for the `dcs` runtime tool
#
# Assumes tailscale, gum, and jq are already present (install.sh ensures this).

set -euo pipefail

if [[ $EUID -ne 0 ]]; then
    exec sudo "$0" "$@"
fi

STATE_DIR=/var/lib/dcs
ENROLL_META="${STATE_DIR}/enrollment.json"
ENROLL_SENTINEL="${STATE_DIR}/enrolled"
DCS_CONF="${DCS_CONF:-/etc/dcs.conf}"

C_BRAND=99
C_OK=42
C_WARN=214
C_ERR=196
C_MUTED=245
C_INFO=75

header()  { gum style --border double --border-foreground "${C_BRAND}" --padding "1 3" --margin "1 0" --foreground "${C_BRAND}" --bold "$@"; }
section() { gum style --foreground "${C_BRAND}" --bold --margin "1 0 0 0" "▸ $*"; }
ok()      { gum style --foreground "${C_OK}"    "✓ $*"; }
warn()    { gum style --foreground "${C_WARN}"  "⚠ $*"; }
err()     { gum style --foreground "${C_ERR}"   "✗ $*"; }
muted()   { gum style --foreground "${C_MUTED}" "$*"; }

slugify() {
    local s="${1,,}"
    s="${s// /-}"
    s="${s//_/-}"
    s="$(printf '%s' "$s" | sed -E 's/[^a-z0-9-]//g; s/-+/-/g; s/^-+|-+$//g')"
    printf '%s' "$s"
}

# Round-trip the OAuth client_credentials flow to confirm the creds in env
# are valid. Returns 0 if Tailscale returns an access_token.
test_oauth_creds() {
    local token
    token=$(curl -sSf -X POST https://api.tailscale.com/api/v2/oauth/token \
        -d "client_id=${DCS_TS_OAUTH_CLIENT_ID:-}" \
        -d "client_secret=${DCS_TS_OAUTH_CLIENT_SECRET:-}" \
        -d "grant_type=client_credentials" 2>/dev/null \
        | jq -r '.access_token // empty' || true)
    [[ -n "${token}" ]]
}

# Ensure ${DCS_CONF} has working OAuth client creds. Walks the operator
# through entry if missing or invalid, then persists. Validates against
# Tailscale's token endpoint before writing so typos are caught immediately.
ensure_oauth_creds() {
    if [[ -f "${DCS_CONF}" ]]; then
        # shellcheck disable=SC1090
        . "${DCS_CONF}"
    fi
    if [[ -n "${DCS_TS_OAUTH_CLIENT_ID:-}" && -n "${DCS_TS_OAUTH_CLIENT_SECRET:-}" ]]; then
        if test_oauth_creds; then
            return 0
        fi
        warn "OAuth creds in ${DCS_CONF} are invalid — let's re-enter them."
    fi

    section "Tailscale OAuth client (one-time)"
    muted "Mint at: https://login.tailscale.com/admin/settings/trust-credentials"
    muted "Scopes: devices:core (Read) + auth_keys (Write, with zabbix-* tags)"
    muted "Client secret starts with 'tskey-client-' (not 'tskey-auth-')."
    muted "Stored in ${DCS_CONF} (0600) so future VMs on this image skip this step."

    while true; do
        DCS_TS_OAUTH_CLIENT_ID=$(gum input --prompt "client id › " \
            --placeholder "short string, no tskey- prefix")
        if [[ -z "${DCS_TS_OAUTH_CLIENT_ID}" ]]; then
            err "client id required"
            continue
        fi
        DCS_TS_OAUTH_CLIENT_SECRET=$(gum input --password --prompt "client secret › ")
        if [[ -z "${DCS_TS_OAUTH_CLIENT_SECRET}" ]]; then
            err "client secret required"
            continue
        fi
        if test_oauth_creds; then
            ok "OAuth creds validated"
            umask 077
            cat > "${DCS_CONF}" <<EOF
# Tailscale API creds. Scopes: devices:core:read, auth_keys (zabbix-* tags).
DCS_TS_OAUTH_CLIENT_ID=${DCS_TS_OAUTH_CLIENT_ID}
DCS_TS_OAUTH_CLIENT_SECRET=${DCS_TS_OAUTH_CLIENT_SECRET}
DCS_TS_TAILNET=${DCS_TS_TAILNET:--}
EOF
            chmod 0600 "${DCS_CONF}"
            export DCS_TS_OAUTH_CLIENT_ID DCS_TS_OAUTH_CLIENT_SECRET
            return 0
        fi
        err "Tailscale rejected those creds. Check the OAuth client, try again."
    done
}

# Read-only check that the tailnet ACL is ready for a Zabbix VM in this
# district. Verifies tag:zabbix-<district> is declared in tagOwners. Prints
# a paste-ready snippet on mismatch and exits. We never write the ACL —
# round-tripping through jq would strip comments from the policy file.
precheck_acl() {
    local district="$1"
    local tag="tag:zabbix-${district}"
    local tailnet="${DCS_TS_TAILNET:--}"

    section "ACL precheck"

    local token
    token=$(curl -sSf -X POST https://api.tailscale.com/api/v2/oauth/token \
        -d "client_id=${DCS_TS_OAUTH_CLIENT_ID:-}" \
        -d "client_secret=${DCS_TS_OAUTH_CLIENT_SECRET:-}" \
        -d "grant_type=client_credentials" 2>/dev/null \
        | jq -r '.access_token // empty' || true)
    if [[ -z "${token}" ]]; then
        warn "Couldn't mint an API token — skipping ACL precheck."
        return 0
    fi

    local acl http
    acl=$(curl -sS -w '\n%{http_code}' \
        -H "Authorization: Bearer ${token}" \
        -H "Accept: application/json" \
        "https://api.tailscale.com/api/v2/tailnet/${tailnet}/acl" 2>/dev/null || true)
    http="${acl##*$'\n'}"
    acl="${acl%$'\n'*}"
    if [[ "${http}" != "200" ]]; then
        warn "ACL read failed (HTTP ${http:-?}) — OAuth client likely lacks policy_file scope."
        muted "Skipping precheck. If auto-mint fails, check tagOwners manually."
        return 0
    fi

    if printf '%s' "${acl}" | jq -e --arg tag "${tag}" '.tagOwners[$tag]' >/dev/null 2>&1; then
        ok "ACL already declares ${tag}"
        return 0
    fi

    err "ACL is missing ${tag} in tagOwners — fix before enrollment:"
    muted "Edit at https://login.tailscale.com/admin/acls/file"
    printf '\n'
    gum style --border normal --border-foreground "${C_INFO}" --padding "0 2" \
        "Add under \"tagOwners\":" \
        "  \"${tag}\": [\"autogroup:admin\"],"
    printf '\n'
    warn "Save the ACL, then re-run: sudo dcs-setup"
    exit 1
}

for tool in tailscale gum jq; do
    command -v "${tool}" >/dev/null 2>&1 || {
        echo "missing dependency: ${tool} — run install.sh first" >&2
        exit 1
    }
done

header \
    "◆ MONITORING SIDE ◆" \
    "" \
    "DCS Zabbix VM Setup" \
    "" \
    "Datacenter VM — reaches school LAN via the district's Pi."

if [[ -f "${ENROLL_SENTINEL}" ]]; then
    warn "This VM is already enrolled as $(jq -r '.district // "?"' "${ENROLL_META}" 2>/dev/null)."
    gum confirm "Re-enroll? This wipes local tailscale state." || exit 0
    tailscale logout 2>/dev/null || true
    rm -f "${ENROLL_SENTINEL}" "${ENROLL_META}"
    ok "Previous state cleared."
fi

# Collect OAuth client creds up-front so the district picker, hostname
# suggestion, and auto-mint all work. Skippable via DCS_AUTHKEY for
# air-gapped / manual-paste workflows.
if [[ -z "${DCS_AUTHKEY:-}" ]]; then
    ensure_oauth_creds
fi

section "District"
muted "Which school district is this VM monitoring?"

# Prefer a picker driven by the Tailscale API (dcs-districts). Falls back
# to free-text if OAuth creds aren't set or the API call fails — the VM
# might legitimately need to be provisioned before its Pi exists.
DISTRICT_RAW=""
DISCOVERY_OK=0
DISTRICT_LIST=""
if command -v dcs-districts >/dev/null 2>&1; then
    if DISTRICT_LIST=$(dcs-districts 2>/dev/null) && [[ -n "${DISTRICT_LIST}" ]]; then
        DISCOVERY_OK=1
    fi
fi

if [[ ${DISCOVERY_OK} -eq 1 ]]; then
    muted "Pi-tagged districts discovered on the tailnet:"
    CHOICES=()
    while IFS= read -r d; do CHOICES+=("${d}"); done <<<"${DISTRICT_LIST}"
    CHOICES+=("(type a new slug — Pi not yet online)")
    PICK=$(gum choose --cursor "› " --header "Pick the school district" "${CHOICES[@]}")
    if [[ "${PICK}" == "(type a new slug — Pi not yet online)" ]]; then
        DISTRICT_RAW=$(gum input --prompt "› " --placeholder "slug, e.g. oakridge")
    else
        DISTRICT_RAW="${PICK}"
    fi
else
    muted "(API discovery unavailable — set OAuth creds in /etc/dcs.conf to enable a picker)"
    DISTRICT_RAW=$(gum input --prompt "› " --placeholder "slug, e.g. oakridge (lowercase, no spaces)")
fi

[[ -n "${DISTRICT_RAW}" ]] || { err "district required"; exit 1; }
DISTRICT="$(slugify "${DISTRICT_RAW}")"
[[ -n "${DISTRICT}" ]] || { err "district reduces to empty slug after sanitizing"; exit 1; }
if [[ "${DISTRICT}" != "${DISTRICT_RAW}" ]]; then
    warn "Sanitized: '${DISTRICT_RAW}' → '${DISTRICT}'"
fi

section "Hostname"

# Suggest the next letter by looking at existing zabbix-<slug>-<letter>
# hostnames on the tailnet. Default "a" if the API isn't reachable or
# no prior VMs exist in this district.
suggest_next_letter() {
    local tag="tag:zabbix-${DISTRICT}" hostnames letters last next
    command -v dcs-query >/dev/null 2>&1 || { echo a; return; }
    # `|| true` so a dcs-query failure (no /etc/dcs.conf, bad OAuth, offline)
    # falls through to the default instead of killing the script under
    # `set -e` + `pipefail`.
    hostnames=$(dcs-query hostnames "${tag}" 2>/dev/null || true)
    letters=$(printf '%s\n' "${hostnames}" \
        | sed -nE "s/^zabbix-${DISTRICT}-([a-z])$/\1/p" \
        | sort -u)
    if [[ -z "${letters}" ]]; then echo a; return; fi
    last=$(printf '%s\n' "${letters}" | tail -1)
    next=$(printf '%s' "${last}" | tr 'a-y' 'b-z')
    [[ "${next}" == "${last}" ]] && next=z  # ran out — best-effort
    echo "${next}"
}
SUGGESTED_LETTER=$(suggest_next_letter)
DEFAULT_HOSTNAME="zabbix-${DISTRICT}-${SUGGESTED_LETTER}"
muted "Default: ${DEFAULT_HOSTNAME}  (suggested based on existing VMs in this district)"
HOSTNAME_HINT=$(gum input --prompt "› " --placeholder "blank → ${DEFAULT_HOSTNAME}")
HOSTNAME_NEW="${HOSTNAME_HINT:-${DEFAULT_HOSTNAME}}"

# Fail fast if the tailnet ACL isn't ready. Skippable via DCS_AUTHKEY
# (operator supplying their own key knows what they're doing).
if [[ -z "${DCS_AUTHKEY:-}" ]]; then
    precheck_acl "${DISTRICT}"
fi

section "Auth key"
AUTHKEY=""
AUTHKEY_SOURCE="manual"
if [[ -n "${DCS_AUTHKEY:-}" ]]; then
    AUTHKEY="${DCS_AUTHKEY}"
    AUTHKEY_SOURCE="env"
    muted "using auth key from \$DCS_AUTHKEY"
else
    muted "Minting a one-hour tag-scoped key for tag:zabbix-${DISTRICT}…"
    MINT_RC=0
    MINT_OUT=$(dcs-mint-key "zabbix-${DISTRICT}" 2>&1) || MINT_RC=$?
    if [[ "${MINT_RC}" -eq 0 && "${MINT_OUT}" == tskey-auth-* ]]; then
        AUTHKEY="${MINT_OUT}"
        AUTHKEY_SOURCE="auto"
        ok "auth key minted"
    else
        err "auto-mint failed:"
        printf '  %s\n' "${MINT_OUT}"
        muted "Common causes:"
        muted "  • tag:zabbix-${DISTRICT} not declared in ACL tagOwners"
        muted "  • OAuth client missing the auth_keys (Write) scope for this tag"
        if gum confirm "Paste a pre-minted auth key instead?"; then
            AUTHKEY=$(gum input --password --prompt "› ")
            [[ -n "${AUTHKEY}" ]] || { err "authkey required"; exit 1; }
        else
            err "aborted"
            exit 1
        fi
    fi
fi

printf '\n'
gum style --border normal --border-foreground "${C_MUTED}" --padding "0 2" \
    "$(gum style --bold --foreground "${C_INFO}" 'Review')" \
    "" \
    "  District    ${DISTRICT}" \
    "  Hostname    ${HOSTNAME_NEW}" \
    "  Expected    tag:zabbix-${DISTRICT}" \
    "  Authkey     ${AUTHKEY:0:12}… (${AUTHKEY_SOURCE})"

gum confirm "Join tailnet?" || { warn "aborted"; exit 1; }

section "Joining tailnet"
hostnamectl set-hostname "${HOSTNAME_NEW}"

# Keep /etc/hosts in sync with the new hostname. Otherwise sudo and
# anything else that resolves the hostname prints
#   unable to resolve host <name>: Temporary failure in name resolution
# on every invocation for the rest of this VM's life.
if grep -qE '^127\.0\.1\.1\b' /etc/hosts; then
    sed -i -E "s|^127\.0\.1\.1.*|127.0.1.1\t${HOSTNAME_NEW}|" /etc/hosts
else
    printf '127.0.1.1\t%s\n' "${HOSTNAME_NEW}" >> /etc/hosts
fi

tailscale up \
    --authkey "${AUTHKEY}" \
    --hostname "${HOSTNAME_NEW}" \
    --ssh \
    --accept-routes \
    --accept-dns=false \
    --reset

sleep 2
EXPECTED_TAG="tag:zabbix-${DISTRICT}"
ACTUAL_TAGS="$(tailscale status --json 2>/dev/null | jq -r '(.Self.Tags // []) | join(",")' 2>/dev/null || echo "")"

section "Tag validation"
if [[ -z "${ACTUAL_TAGS}" ]]; then
    err "TAGCHECK FAIL: node has no tags"
    muted "The authkey was not tag-scoped. Fix:"
    muted "  1. Admin console → Machines → remove this node"
    muted "  2. Mint a new authkey with Tags = ${EXPECTED_TAG}"
    muted "  3. Run: sudo dcs reset && sudo dcs-setup"
elif [[ ",${ACTUAL_TAGS}," = *",${EXPECTED_TAG},"* ]]; then
    ok "TAGCHECK PASS: ${ACTUAL_TAGS}"
else
    err "TAGCHECK FAIL: expected ${EXPECTED_TAG}; got ${ACTUAL_TAGS}"
    muted "The authkey was scoped to the wrong tag. Fix as above with correct tag."
fi

mkdir -p "${STATE_DIR}"
jq -n \
    --arg hostname    "${HOSTNAME_NEW}" \
    --arg district    "${DISTRICT}" \
    --arg enrolled_at "$(date -u +%FT%TZ)" \
    '{hostname:$hostname, district:$district, role:"zabbix", enrolled_at:$enrolled_at}' \
    > "${ENROLL_META}"
touch "${ENROLL_SENTINEL}"

gum style \
    --border double --border-foreground "${C_OK}" \
    --padding "1 3" --margin "1 0" \
    --foreground "${C_OK}" --bold \
    "✓ Setup complete" \
    "" \
    "This VM reaches ${DISTRICT}'s school LAN via the district's Pi." \
    "Add Zabbix hosts by their real IPs — no translation needed." \
    "Check state anytime with: sudo dcs status"
