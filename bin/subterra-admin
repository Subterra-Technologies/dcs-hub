#!/usr/bin/env bash
# Thin wrapper around `headscale` for Subterra's daily fleet ops.
#
# Conventions:
#   - Every school district maps to one Headscale "user". The district
#     slug IS the user name.
#   - Every node in a district (Pi or Zabbix VM) belongs to that user.
#   - Tags: "pi", "zabbix", "ops" — set via --tags on preauthkey creation.
#   - Same-district access enforced by ACL (autogroup:self).
set -euo pipefail

cmd="${1:-}"
shift || true

usage() {
    cat <<EOF
usage: subterra-admin <command> [args]

  add-district <slug>
      Create a Headscale user for a new school district.

  list-districts
      List all district users.

  issue-token <district> <pi|zabbix> [--expiration 3d] [--ephemeral]
      Generate a pre-auth key for a new node. Prints the raw key to stdout.
      Give this key to the Pi (in /boot/firmware/subterra-enroll.json) or
      to the Zabbix VM at tailscale-up time. Default 3d to keep pre-ship
      NVMes short-lived; pass --expiration 7d etc. for longer windows.

  keys list [<district>]
      Show outstanding (unused, unexpired) pre-auth keys. Catches keys
      that were issued but never claimed — e.g. Pis lost in transit or
      ops forgot to ship.

  list-nodes [<district>]
      List registered nodes, optionally filtered by district.

  routes [<district>]
      Show advertised subnet routes. Routes under RFC1918 are auto-approved
      by ACL for tag:pi. Override manually via: headscale routes enable -r <id>.

  approve-route <route-id>
      Force-approve a specific advertised route (for non-RFC1918 cases).

  delete-node <hostname>
      Remove a node from the tailnet. Use for revocation or rotation.

  policy-reload
      Re-apply /etc/headscale/acl.hujson.

Environment: HEADSCALE="${HEADSCALE:-sudo headscale}"
EOF
}

HEADSCALE="${HEADSCALE:-sudo headscale}"

# Resolve a district slug to the numeric Headscale user ID.
# Headscale's `preauthkeys create --user` takes a uint, not a name.
user_id_for() {
    local slug="$1"
    local uid
    uid="$(${HEADSCALE} --output json users list 2>/dev/null | \
           jq -r --arg s "${slug}" '.[] | select(.name==$s) | .id')"
    if [[ -z "${uid}" ]]; then
        echo "no district '${slug}' — create it first with add-district" >&2
        return 1
    fi
    echo "${uid}"
}

case "${cmd}" in
    add-district)
        slug="${1:?district slug required}"
        ${HEADSCALE} users create "${slug}"
        echo "district '${slug}' created"
        ;;

    list-districts)
        ${HEADSCALE} users list
        ;;

    issue-token)
        slug="${1:?district slug required}"
        role="${2:?role required (pi|zabbix)}"
        shift 2
        if [[ "${role}" != "pi" && "${role}" != "zabbix" ]]; then
            echo "role must be 'pi' or 'zabbix'" >&2
            exit 2
        fi
        expiration="3d"
        reusable_flag=""
        ephemeral_flag=""
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --expiration) expiration="$2"; shift 2 ;;
                --reusable) reusable_flag="--reusable"; shift ;;
                --ephemeral) ephemeral_flag="--ephemeral"; shift ;;
                *) echo "unknown flag $1"; exit 2 ;;
            esac
        done
        uid="$(user_id_for "${slug}")"
        # shellcheck disable=SC2086
        ${HEADSCALE} preauthkeys create \
            --user "${uid}" \
            --expiration "${expiration}" \
            --tags "tag:${role}" \
            ${reusable_flag} ${ephemeral_flag}
        ;;

    list-nodes)
        # `nodes list --user` takes the name string (NOT the numeric id).
        slug="${1:-}"
        if [[ -n "${slug}" ]]; then
            ${HEADSCALE} nodes list --user "${slug}"
        else
            ${HEADSCALE} nodes list
        fi
        ;;

    routes)
        slug="${1:-}"
        if [[ -n "${slug}" ]]; then
            ${HEADSCALE} --output json nodes list --user "${slug}" | \
                jq -r '.[] | {id,name,available_routes:.availableRoutes,approved:.approvedRoutes}'
        else
            ${HEADSCALE} --output json nodes list | \
                jq -r '.[] | {id,name,available_routes:.availableRoutes,approved:.approvedRoutes}'
        fi
        ;;

    approve-route)
        node_id="${1:?node id required}"
        route="${2:?route (e.g. 192.168.1.0/24) required}"
        ${HEADSCALE} nodes approve-routes --identifier "${node_id}" --routes "${route}"
        ;;

    delete-node)
        host="${1:?node hostname required}"
        nid="$(${HEADSCALE} nodes list --output json | \
               jq -r --arg h "${host}" '.[] | select(.given_name==$h or .name==$h) | .id')"
        if [[ -z "${nid}" ]]; then
            echo "no node named '${host}'" >&2
            exit 1
        fi
        ${HEADSCALE} nodes delete -i "${nid}" --force
        ;;

    policy-reload)
        ${HEADSCALE} policy set -f /etc/headscale/acl.hujson
        ;;

    keys)
        sub="${1:-}"; shift || true
        case "${sub}" in
            list)
                slug="${1:-}"
                now="$(date -u +%s)"
                # preauthkeys list returns ALL keys (no --user filter in v0.28).
                # We post-filter on .user.name in jq. Each entry has .user, .acl_tags,
                # .used (bool|null), .expiration.seconds (unix).
                keys_json="$(${HEADSCALE} --output json preauthkeys list 2>/dev/null || echo '[]')"
                printf '%-20s %-12s %-10s %s\n' "DISTRICT" "EXPIRES-IN" "TAGS" "KEY-PREFIX"
                jq -r --arg slug "${slug}" --arg now "${now}" '
                    .[]
                    | select($slug == "" or .user.name == $slug)
                    | select((.used // false) == false)
                    | select((.expiration.seconds // 0) > ($now | tonumber))
                    | [
                        .user.name,
                        (((.expiration.seconds) - ($now | tonumber)) / 3600 | floor | tostring + "h"),
                        ((.acl_tags // []) | join(",")),
                        (.key | .[0:16] + "...")
                      ] | @tsv
                ' <<<"${keys_json}" | while IFS=$'\t' read -r d e t k; do
                    printf '%-20s %-12s %-10s %s\n' "${d}" "${e}" "${t}" "${k}"
                done
                ;;
            *)
                echo "usage: subterra-admin keys list [<district>]" >&2
                exit 2
                ;;
        esac
        ;;

    ""|help|--help|-h)
        usage
        ;;

    *)
        echo "unknown command: ${cmd}" >&2
        usage
        exit 2
        ;;
esac
