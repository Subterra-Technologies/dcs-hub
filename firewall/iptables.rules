*filter
:INPUT DROP [0:0]
:FORWARD DROP [0:0]
:OUTPUT ACCEPT [0:0]

-A INPUT -i lo -j ACCEPT
-A INPUT -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT
-A INPUT -m conntrack --ctstate INVALID -j DROP

# Management SSH + fleet dashboard: only from the ops/DC network.
-A INPUT -s __MGMT_CIDR__ -p tcp --dport 22   -j ACCEPT
-A INPUT -s __MGMT_CIDR__ -p tcp --dport 8081 -j ACCEPT

-A INPUT -p icmp -j ACCEPT

# No public inbound ports: cloudflared dials OUT to Cloudflare edge and
# handles TLS termination at Cloudflare. Headscale listens on 127.0.0.1:8080.
# If you ever run without Cloudflare Tunnel, open TCP/80 + TCP/443 here
# and restore tls_letsencrypt_* in headscale/config.yaml.

COMMIT
