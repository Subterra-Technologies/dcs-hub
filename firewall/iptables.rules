*filter
:INPUT DROP [0:0]
:FORWARD DROP [0:0]
:OUTPUT ACCEPT [0:0]

-A INPUT -i lo -j ACCEPT
-A INPUT -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT
-A INPUT -m conntrack --ctstate INVALID -j DROP

# Management SSH + fleet dashboard: only from the ops/DC network.
-A INPUT -s __MGMT_CIDR__ -p tcp --dport 22   -j ACCEPT
-A INPUT -s __MGMT_CIDR__ -p tcp --dport 8081 -j ACCEPT

# Headscale public API + ACME HTTP-01 challenge.
# (Remove 80/443 when running behind Cloudflare Tunnel — see task #28.)
-A INPUT -p tcp --dport 80  -j ACCEPT
-A INPUT -p tcp --dport 443 -j ACCEPT

-A INPUT -p icmp -j ACCEPT

# Coordinator does not route traffic between schools and Zabbix VMs.
# Each Zabbix VM runs its own Tailscale tunnel directly to its paired Pi.

COMMIT
